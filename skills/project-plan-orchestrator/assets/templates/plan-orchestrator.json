{
  "schema_version": 1,
  "strictness": "normal",
  "plan_path": "PLAN.md",
  "work_globs": [
    "docs/work/W-*.md"
  ],
  "bug_log_path": "docs/BUGS.md",
  "test_log_path": "docs/TEST_LOG.md",
  "delivery_globs": [
    "src/**",
    "app/**",
    "lib/**",
    "packages/**",
    "tests/**",
    "Assets/**",
    "ProjectSettings/**",
    ".github/**",
    "**/*.py",
    "**/*.pyi",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "**/*.java",
    "**/*.kt",
    "**/*.cs",
    "**/*.cpp",
    "**/*.c",
    "**/*.h",
    "**/*.hpp",
    "**/*.go",
    "**/*.rs",
    "**/*.swift",
    "**/*.rb",
    "**/*.php",
    "**/*.sh",
    "**/*.ps1",
    "**/*.json",
    "**/*.toml",
    "**/*.yaml",
    "**/*.yml",
    "**/*.unity",
    "**/*.prefab",
    "**/*.asset",
    "**/*.shader",
    "**/*.uxml",
    "**/*.uss"
  ],
  "exempt_globs": [
    ".git/**",
    ".project-plan/**",
    "docs/**",
    "PLAN.md",
    "README.md",
    "LICENSE",
    "plan-orchestrator.json",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/node_modules/**",
    "**/Library/**",
    "**/Temp/**",
    "**/Logs/**",
    "**/build/**",
    "**/dist/**",
    "**/bin/**",
    "**/obj/**"
  ],
  "instruction_targets": [
    "AGENTS.md",
    "CLAUDE.md"
  ]
}
